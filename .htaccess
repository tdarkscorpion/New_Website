# ----------------------------------------------------------------------
# | Security Hardening and Performance Options                        |
# ----------------------------------------------------------------------

# 1. Protect sensitive files (Credentials, Logs, Configs, DB)
# This is placed first to ensure absolute protection
<FilesMatch "(^#.*#$)|(\.(bak|config|sql|sql\.gz|php~|php_bak|env|txt|json|log)|config\.php|Database\.php|credentials\.env|whitelist\.env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# 2. Custom Error Pages
ErrorDocument 403 /403.php

# 3. Disable Directory Indexing
# This prevents hackers from seeing the list of files in your folders
Options -Indexes

# 4. Security Headers
<IfModule mod_headers.c>
    # Prevent the site from being embedded in iframes on other domains (Anti-Clickjacking)
    Header set X-Frame-Options "SAMEORIGIN"

    # Block the browser from trying to guess the content type (Security)
    Header set X-Content-Type-Options "nosniff"

    # Enable browser XSS protection
    Header set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy (Basic Protection)
    # Allows scripts from same origin and trusted CDNs
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://code.jquery.com https://unpkg.com https://kit.fontawesome.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://kit-free.fontawesome.com; font-src 'self' https://fonts.gstatic.com https://ka-f.fontawesome.com; img-src 'self' data: https:; connect-src 'self' https://ka-f.fontawesome.com;"
</IfModule>

# 5. PHP Security Tweaks (If allowed by host)
<IfModule mod_php.c>
    php_flag session.cookie_httponly on
    php_flag session.cookie_secure on
    php_flag display_errors off
</IfModule>

